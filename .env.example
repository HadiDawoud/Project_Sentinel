# Sentinel Configuration

# Config file path
SENTINEL_CONFIG_PATH=config.yaml

# Model settings
SENTINEL_MODEL_NAME=distilbert-base-uncased
SENTINEL_MODEL_PATH=models/checkpoints

# Logging
SENTINEL_LOG_LEVEL=INFO

# Cache settings (0 to disable)
SENTINEL_CACHE_SIZE=0

# API Key (optional, for authentication)
SENTINEL_API_KEY=your-api-key-here

# CUDA settings
CUDA_VISIBLE_DEVICES=0
